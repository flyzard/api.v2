# Copy to .env and fill in. .env is gitignored — never commit it.

# SAF-T Header software identity (AT-assigned at certification)
PRODUCER_TAX_ID=000000000
SOFTWARE_NAME=MySoftware
PRODUCER_NAME="My Company Lda"
VERSION=1.0.0
CERTIFICATE_NUMBER=0000

# AT document-signing private key (RSA-1024 PEM, PKCS#1 or PKCS#8).
# Keep outside the repo; in production inject via secret manager.
# Unset = demo falls back to the dev stub signer.
AT_SIGNING_KEY_FILE=/absolute/path/to/at_private.pem
AT_PUBLIC_KEY_FILE=/absolute/path/to/public_key.txt
